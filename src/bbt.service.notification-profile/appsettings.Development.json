{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=server; Database=db; Integrated Security=true; MultipleActiveResultSets=true",
    "ReminderConnectionString": "Server=server; User=user; password=pass; database=db; pooling=true; Max Pool Size=100; Min Pool Size=8",
    "RedisConnection": "localhost:6379,abortConnect=False"
  },
  "CustomerProfileEndpoint": "XXX",

  "MetricsOptions": {
    "DefaultContextLabel": "Bbt_notification_profile_services",
    "Enabled": true
  },
  "MetricsWebTrackingOptions": {
    "ApdexTrackingEnabled": true,
    "ApdexTSeconds": 0.1,
    "IgnoredHttpStatusCodes": [],
    "IgnoredRoutesRegexPatterns": [],
    "OAuth2TrackingEnabled": true
  },
  "MetricEndpointsOptions": {
    "MetricsEndpointEnabled": true,
    "MetricsTextEndpointEnabled": true,
    "EnvironmentInfoEndpointEnabled": true
  },
  "ElasticApm": {
    "SecretToken": "secretToken",
    "ServerUrl": "serverUrl",
    "ServiceName": "serviceName",
    "Environment": "Dev",
    "TransactionSampleRate": 1.0,
    "CaptureBody": "all",
    "CaptureBodyContentTypes": "application/x-www-form-urlencoded*, text/*, application/json*, application/xml*"
  },
  "redis": {
    "name": "redistest",
    "host": "localhost",
    "port": 6379,
    "allowAdmin": true,
    "ssl": true,
    "abortConnect": "False"
  },

}

