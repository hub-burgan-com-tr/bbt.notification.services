{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {


    "DefaultConnection": "Server=localhost; Database=Reminder; User Id=XXXX;Password=YYYY; MultipleActiveResultSets=true",
    "ReminderConnectionString": "Server=server; User=user; password=key; database=db",
    "RedisConnection": "redistest"

  },
    "CustomerProfileEndpoint": "XXX",

    "MetricsOptions": {
      "DefaultContextLabel": "Bbt_notification_profile_services",
      "Enabled": true
    },
    "MetricsWebTrackingOptions": {
      "ApdexTrackingEnabled": true,
      "ApdexTSeconds": 0.1,
      "IgnoredHttpStatusCodes": [],
      "IgnoredRoutesRegexPatterns": [],
      "OAuth2TrackingEnabled": true
    },
    "MetricEndpointsOptions": {
      "MetricsEndpointEnabled": true,
      "MetricsTextEndpointEnabled": true,
      "EnvironmentInfoEndpointEnabled": true
    },
    "ElasticApm": {
      "SecretToken": "secretToken",
      "ServerUrl": "serverUrl",
      "ServiceName": "serviceName",
      "Environment": "Dev",
      "TransactionSampleRate": 1.0,
      "CaptureBody": "all",
      "CaptureBodyContentTypes": "application/x-www-form-urlencoded*, text/*, application/json*, application/xml*"
    },
    "redis": {
      "name": "redistest",
      "host": "localhost",
      "port": 6379,
      "allowAdmin": true,
      "ssl": true,
      "abortConnect": "False"
    }

  }

